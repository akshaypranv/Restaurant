# Database Connection URL (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/silvertip_cafe

# JWT Authentication
JWT_SECRET=your-minimum-32-character-secret-key-here
JWT_EXPIRES_IN=24h

# Express Server Port and Environment
PORT=5000
NODE_ENV=development

# Security / CORS Whitelist
ALLOWED_ORIGINS=http://localhost:5173,https://your-site.netlify.app
